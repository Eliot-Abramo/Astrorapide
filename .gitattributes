# Keep only genuinely large binary project assets in Git LFS.
*.bit filter=lfs diff=lfs merge=lfs -text
*.hwh filter=lfs diff=lfs merge=lfs -text
*.txz filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.ods filter=lfs diff=lfs merge=lfs -text

# Normalize source and documentation as text.
* text=auto
*.sh text eol=lf
*.py text eol=lf
*.tcl text eol=lf
